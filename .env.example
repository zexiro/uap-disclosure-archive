# Copy to ".env" and fill in values. .env is git-ignored.

# OpenRouter — powers /api/ask (public, cheap)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324

# Anthropic — powers /api/enrich (owner-only, uses web_search)
ANTHROPIC_API_KEY=sk-ant-...

# Switches
ASK_ENABLED=true       # /api/ask + ⌘K modal visible to all
ENRICH_ENABLED=true    # /api/enrich visible to owner only

# Owner token — visit ?owner=<token> once on a non-localhost URL to enroll
ASK_OWNER_TOKEN=change-me-to-a-long-random-string

# Rate limits
ASK_RATE_PUBLIC=10
ASK_RATE_OWNER=60
ASK_GLOBAL_DAILY_CAP=500

# Server bind (Railway sets PORT)
# PORT=8000
# BIND=0.0.0.0
