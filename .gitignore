# Bulk binary assets — Railway volume holds these in production; locally rebuilt by scripts/download.py
raw/docs/
raw/docs_ocr/
raw/images/
raw/images_extracted/
raw/images_enhanced/
raw/images_depth/
raw/thumbs/
raw/videos/

# Multi-source sightings: bulk artifacts rebuilt by scripts/sightings/*.
# We DO commit raw/sightings/correlations.json and raw/sightings/geocache.json
# (small, avoids re-geocoding on every container boot). Blue Book is small
# (~553 cases at <300KB) so we commit its normalized form too — only the
# bulk-redownloadable raw/ folder is excluded.
raw/sightings/nuforc/raw/
raw/sightings/nuforc/sightings.json
raw/sightings/blue_book/raw/
raw/sightings/reddit/raw/
raw/sightings/reddit/sightings.json
raw/sightings/news/raw/
raw/sightings/news/sightings.json
raw/sightings/sightings.json

# Logs and temp
raw/*.log
raw/**/*.part
# Hourly change-watcher writes this sentinel when it sees drift; the
# entrypoint loop consumes it then deletes it. Never commit — a stale
# committed copy would force an unnecessary refresh on every fresh boot.
raw/wargov_changes_pending
*.pyc
__pycache__/
.DS_Store

# Local-only HTTP server pidfile etc
/tmp/

# Secrets — never commit
.env
.env.local
.env.*.local

# AI enrichment output — local-only review state
ui/enrichments/

# Local agent state (Claude Code etc.)
.claude/

# Note: we DO commit raw/text, raw/csv, raw/dvids_meta, raw/records.json,
# raw/links.json, raw/downloads.tsv, ui/search-index.json, and the vault.
# That keeps the repo ~15 MB so the UI works the moment the container boots,
# even before the volume sync finishes.
